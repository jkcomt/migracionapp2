<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core">

    <Dialog
        id="idCargaValueHelpDialog"
        title="Seleccionar ID de Carga"
        contentWidth="60%"
        contentHeight="400px"
        draggable="true"
        resizable="true">

        <subHeader>
            <OverflowToolbar>
                <SearchField
                    id="idCargaSearchField"
                    width="240px"
                    placeholder="Buscar por ID de Carga..."
                    liveChange=".onValueHelpSearch"/>

                <DatePicker
                    id="fechaCargaField"
                    width="170px"
                    placeholder="e.g. 31/12/2026"
                    displayFormat="dd/MM/yyyy"
                    valueFormat="yyyy-MM-dd" />

                <Input
                    id="usuarioSelectField"
                    width="170px"
                    placeholder="Usuario"
                    showValueHelp="false" />

                <Select
                    id="estadoSelectField"
                    
                    selectedKey="Todos">
                    <core:Item key="Todos" text="Todos" />
                    <core:Item key="Procesando" text="Procesando" />
                    <core:Item key="Procesado" text="Procesado" />
                    <core:Item key="Error" text="Error" />
                </Select>
                <ToolbarSpacer />
                <Button
                    text="Buscar"
                    icon="sap-icon://search"
                    type="Emphasized"
                    press=".onBuscar" />

                <Button
                    text="Limpiar"
                    type="Transparent"
                    press=".onLimpiar" />
            </OverflowToolbar>
        </subHeader>

        <content>
            <Table
                id="idCargaTable"
                items="{path:'oMainModel>/CargaMasiva', sorter:{path:'LocalCreatedAt', descending:true}}"
                mode="None"
                growing="true"
                growingThreshold="15">

                <columns>
                    <Column width="20%">
                        <Text text="FileName" />
                    </Column>
                    <Column width="30%">
                        <Text text="ID Carga" />
                    </Column>
                    <Column width="20%">
                        <Text text="Fecha de Carga" />
                    </Column>
                    <Column>
                        <Text text="Usuario" />
                    </Column>
                    <Column>
                        <Text text="Estado" />
                    </Column>
                    <Column visible="false">
                        <Text text="Total Registros" />
                    </Column>
                    <Column visible="false">
                        <Text text="Total Procesados" />
                    </Column>
                    <Column visible="false">
                        <Text text="Total Con Errores" />
                    </Column>
                    <Column visible="false">
                        <Text text="Total Con Pendientes" />
                    </Column>
                </columns>

                <items>
                    <ColumnListItem type="Active" press=".onValueHelpItemPress">
                        <cells>
                            <Text text="{oMainModel>Filename}" />
                            <Text text="{oMainModel>UploadUuid}" />
                            <Text text="{oMainModel>LocalCreatedAt}" />
                            <Text text="{oMainModel>LocalCreatedBy}" />
                            <ObjectStatus
                                text="{oMainModel>Status}"
                                state="{= ${oMainModel>Status} === 'Procesado'
                                    ? 'Success'
                                    : ${oMainModel>Status} === 'Error'
                                        ? 'Error'
                                        : 'Warning' }" />
                            <Text text="{oMainModel>TotalRows}" />
                            <Text text="{oMainModel>RowsSuccess}" />
                            <Text text="{oMainModel>RowsError}" />
                            <Text text="{oMainModel>RowsPend}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>

        <endButton>
            <Button
                text="Cancelar"
                press=".onValueHelpCancel" />
        </endButton>
    </Dialog>

</core:FragmentDefinition>